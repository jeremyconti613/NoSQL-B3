# ---- Neo4j ----
# Used by the neo4j container itself (format: user/password)
NEO4J_AUTH=neo4j/musicgraph_password
# Used by the backend to connect (bolt protocol)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=musicgraph_password

# ---- Backend ----
BACKEND_PORT=8080
# MusicBrainz requires a descriptive, identifying User-Agent on every request.
# Format recommended by MusicBrainz: "AppName/Version ( contact-url-or-email )"
MUSICBRAINZ_USER_AGENT=MusicGraph/0.1 ( https://github.com/your-user/musicgraph )
MUSICBRAINZ_BASE_URL=https://musicbrainz.org/ws/2
# Origin allowed to call the API (CORS). Set to your frontend's URL.
FRONTEND_ORIGIN=http://localhost:5173
# If set and the file exists, the seed binary loads this snapshot instead of
# hitting MusicBrainz live (offline, no rate limiting, deterministic).
SEED_FILE=/app/data/seed.json

# ---- Frontend ----
# Base URL the frontend uses to reach the backend API.
VITE_API_URL=http://localhost:8080/api
